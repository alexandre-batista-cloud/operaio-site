---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Operaio — SEO Local e Sites que Convertem em Goiânia',
  description = 'Agência de SEO local em Goiânia-GO. Fazemos seu negócio aparecer no Google, converter no site e fechar mais clientes — 100% remoto. Diagnóstico gratuito.',
  ogImage = '/og-image.png',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <link rel="sitemap" href="/sitemap-index.xml" />

  <!-- OG -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={new URL(ogImage, Astro.site)} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="pt_BR" />
  <meta property="og:url" content={canonical} />
  <meta property="og:site_name" content="Operaio" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <!-- Schema.org -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "LocalBusiness",
    "name": "Operaio",
    "description": "Sistema digital para negócios locais — SEO, site e operação integrados",
    "url": "https://operaio.com.br",
    "email": "contato@operaio.com.br",
    "areaServed": { "@type": "Country", "name": "Brasil" },
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "Av. 85, 2385",
      "addressLocality": "Goiânia",
      "addressRegion": "GO",
      "addressCountry": "BR"
    },
    "telephone": "+55-62-99614-8873",
    "openingHours": ["Mo-Fr 09:00-19:00", "Sa 09:00-13:00"],
    "serviceType": ["SEO Local", "Desenvolvimento Web", "Marketing Digital"]
  }
  </script>

  <!-- Google Analytics 4 (TODO: substituir GA4_OPERAIO_ID pelo Measurement ID criado em analytics.google.com) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=GA4_OPERAIO_ID"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'GA4_OPERAIO_ID');
  </script>

  <!-- Microsoft Clarity — heatmap + scroll depth (TODO: substituir CLARITY_OPERAIO_ID pelo project ID criado em clarity.microsoft.com) -->
  <script type="text/javascript">
    (function(c,l,a,r,i,t,y){
      c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
      t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
      y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
    })(window,document,"clarity","script","vyj7f5ff5g");
  </script>
</head>
<body>
  <Header />
  <main>
    <slot />
  </main>
  <Footer />
</body>
</html>
