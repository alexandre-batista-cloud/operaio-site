<style>
  /* ============================================================
     DOBRAS MAP — referência rápida para edições futuras
     D0  Header         sticky nav          → Header.astro
     D1  Hero           .dobra-hero         → L109-250
     D2  Marquee        .dobra-marquee      → L255-296
     D3  Problema       .dobra-problema     → L301-345
     D4  Processo       #como-funciona      → L350-390
     D5  Caso Real      .dobra-caso-real    → L395-493
     D6  Serviços       #servicos           → L498-581
     D7  Founder        #sobre              → L586-672
     D8  Blog           .dobra-blog         → L677-699
     D9  CTA            .dobra-cta          → L704-740
     D10 Contato        #contato            → L745-878
     D11 Footer         Footer.astro
     ============================================================ */

  /* === ANIMAÇÃO BADGE HERO === */
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }

  /* === CONNECTING LINE — D4 Processo === */
  .steps-line {
    position: absolute;
    top: 25px;
    left: calc(100% / 6);
    right: calc(100% / 6);
    height: 2px;
    background: var(--border);
    z-index: 0;
  }

  /* ============================================================
     RESPONSIVIDADE — Tablet (≤1024px)
     ============================================================ */
  @media (max-width: 1024px) {
    /* D1 Hero — reduz padding topo */
    .dobra-hero { padding: 5.5rem 0 4rem !important; }

    /* D3 Problema — 2×2 em tablet */
    .problema-grid { grid-template-columns: repeat(2, 1fr) !important; }

    /* D6 Pacotes — 2×2 em tablet */
    .pacotes-grid { grid-template-columns: repeat(2, 1fr) !important; }

    /* D7 Founder — gap menor em tablet */
    #sobre .grid-2col { gap: 3rem !important; }
  }

  /* ============================================================
     RESPONSIVIDADE — Mobile (≤768px)
     ============================================================ */
  @media (max-width: 768px) {
    /* D1 Hero */
    .dobra-hero { padding: 4rem 0 2.5rem !important; }

    /* D3 Problema */
    .dobra-problema { padding: 3rem 0 !important; }
    .problema-grid { grid-template-columns: repeat(2, 1fr) !important; }

    /* D6 Pacotes */
    .pacotes-grid { grid-template-columns: repeat(1, 1fr) !important; }

    /* D4 Processo */
    #como-funciona { padding: 3rem 0 !important; }
    .steps-line { display: none !important; }
    .steps-h-grid {
      grid-template-columns: 1fr !important;
      gap: 2rem !important;
      max-width: 280px !important;
      margin: 0 auto !important;
    }
    /* No mobile steps ficam alinhados à esquerda */
    .steps-h-grid > div {
      align-items: flex-start !important;
      text-align: left !important;
    }

    /* D5 Caso Real */
    .dobra-caso-real { padding: 3rem 0 !important; }
    /* Fix grid child overflow (min-width:auto default) */
    .dobra-caso-real .grid-2col > div { min-width: 0; }
    /* Metric comparison row: wrap on small screens */
    .dobra-caso-real [style*="align-items:flex-end"] {
      flex-wrap: wrap !important;
      gap: 0.75rem !important;
    }

    /* D6 Serviços */
    #servicos { padding: 3rem 0 !important; }

    /* D7 Founder */
    #sobre { padding: 3rem 0 !important; }
    #sobre .grid-2col { gap: 2.5rem !important; }

    /* D8 Blog */
    .dobra-blog { padding: 2.5rem 0 !important; }

    /* D9 CTA */
    .dobra-cta { padding: 3rem 0 !important; }

    /* D10 Contato */
    #contato { padding: 3.5rem 0 !important; }
    .contact-form { padding: 1.5rem !important; }

    /* Grids 2col → empilha */
    .grid-2col {
      grid-template-columns: 1fr !important;
      gap: 2.5rem !important;
    }
    /* Prevent grid children from overflowing their cells */
    .grid-2col > * { min-width: 0; }

    /* Seletor genérico fallback para grids inline */
    section > .container > div[style*="grid-template-columns: 1fr 1fr"] {
      grid-template-columns: 1fr !important;
      gap: 2.5rem !important;
    }

    /* Hero step strip: padding menor */
    .hero-steps-strip { max-width: 100% !important; }

    /* Stats strip: full width mobile */
    .hero-stats { max-width: 100% !important; }
  }

  /* ============================================================
     RESPONSIVIDADE — Small mobile (≤480px)
     ============================================================ */
  @media (max-width: 480px) {
    /* Hero step strip: ocultar em telas muito pequenas
       (o processo está coberto pela D4) */
    .hero-steps-strip { display: none !important; }

    /* Metrics grid 2col → 1col */
    div[style*="grid-template-columns:1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }

    /* Form padding mínimo */
    .contact-form { padding: 1.25rem !important; }

    /* CTA block texto menor */
    .dobra-cta h2 {
      font-size: clamp(1.25rem, 5vw, 1.75rem) !important;
    }
  }
</style>
