---
import Layout from '../layouts/Layout.astro';

const pacotes = [
  {
    nome: 'Diagnóstico Raio-X',
    subtitulo: 'Onde você está perdendo vendas',
    preco: 'R$497',
    recorrencia: 'único',
    destaque: false,
    itens: [
      'Auditoria completa do site',
      'Análise de posicionamento Google',
      'Relatório de oportunidades locais',
      'Mapa de atrito digital',
      'Plano de ação em 30 dias',
    ],
    cta: 'Quero meu diagnóstico',
  },
  {
    nome: 'Vitrine Inteligente',
    subtitulo: 'Presença local que converte',
    preco: 'R$2.800',
    recorrencia: '+ R$1.200/mês',
    destaque: false,
    itens: [
      'Site otimizado para SEO local',
      'Google Meu Negócio configurado',
      'Schema markup completo',
      'Relatório mensal de posições',
      'Suporte e ajustes contínuos',
    ],
    cta: 'Começar agora',
  },
  {
    nome: 'Landing de Conversão',
    subtitulo: 'Página que fecha clientes',
    preco: 'R$2.500',
    recorrencia: '+ R$900/mês',
    destaque: true,
    itens: [
      'Landing page de alta conversão',
      'Copywriting estratégico',
      'Integração com WhatsApp/e-mail',
      'Testes A/B contínuos',
      'Analytics e relatório semanal',
    ],
    cta: 'Quero converter mais',
  },
  {
    nome: 'Site Authority',
    subtitulo: 'Autoridade total no digital',
    preco: 'R$7.000',
    recorrencia: '+ R$2.500/mês',
    destaque: false,
    itens: [
      'Site completo multi-página',
      'Blog com estratégia de conteúdo',
      'SEO técnico avançado',
      'GEO — citações em IA',
      'Gestão digital full service',
    ],
    cta: 'Quero ser autoridade',
  },
];

const etapas = [
  {
    num: '01',
    titulo: 'Diagnóstico',
    desc: 'Mapeamos onde seu negócio está perdendo vendas no digital: posicionamento Google, site, operação. 30 minutos, resultado concreto.',
  },
  {
    num: '02',
    titulo: 'Sistema',
    desc: 'Montamos o sistema digital certo para o seu negócio. Site, SEO local, Google Meu Negócio — tudo integrado e funcionando junto.',
  },
  {
    num: '03',
    titulo: 'Resultado',
    desc: 'Mais cliques no Google, mais visitas, mais conversões. Acompanhamos os números e ajustamos continuamente para crescer.',
  },
];

const valores = [
  {
    icone: '◈',
    titulo: 'Integridade',
    desc: 'Dizemos o que é possível, entregamos o que prometemos. Sem métricas de vaidade, sem relatórios vazios.',
  },
  {
    icone: '◎',
    titulo: 'Responsabilidade',
    desc: 'Seu resultado é nossa responsabilidade. Não desaparecemos após o setup — acompanhamos cada etapa.',
  },
  {
    icone: '◆',
    titulo: 'Visão de resultado',
    desc: 'Cada decisão técnica existe para gerar negócio. SEO, site e conteúdo como sistema de vendas, não como custo.',
  },
];
---

<Layout>

  <!-- ═══════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════ -->
  <section style="
    padding: 7rem 0 5rem;
    position: relative;
    overflow: hidden;
  ">
    <!-- Dot grid texture -->
    <div class="hero-texture"></div>

    <!-- Background glow -->
    <div style="
      position: absolute;
      top: -200px;
      right: -200px;
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(16,185,129,0.08) 0%, transparent 70%);
      pointer-events: none;
    "></div>
    <div style="
      position: absolute;
      bottom: -100px;
      left: -100px;
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(240,90,40,0.05) 0%, transparent 70%);
      pointer-events: none;
    "></div>

    <div class="container" style="position: relative; z-index: 1;">
      <!-- Badge -->
      <div style="
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(16,185,129,0.1);
        border: 1px solid rgba(16,185,129,0.2);
        padding: 0.375rem 1rem;
        border-radius: 100px;
        margin-bottom: 2rem;
      ">
        <span style="width: 6px; height: 6px; background: var(--accent); border-radius: 50%; display: inline-block; animation: pulse 2s infinite;"></span>
        <span style="color: var(--accent); font-size: 0.8rem; font-weight: 600; letter-spacing: 0.05em;">SISTEMA DIGITAL PARA NEGÓCIOS LOCAIS · BRASIL</span>
      </div>

      <!-- Headline -->
      <h1 style="
        font-size: clamp(2.75rem, 6vw, 5rem);
        font-weight: 900;
        line-height: 1.05;
        letter-spacing: -0.03em;
        max-width: 800px;
        margin-bottom: 1.75rem;
      ">
        Negócios locais que<br/>
        <span style="color: var(--accent);">vendem de verdade.</span>
      </h1>

      <p style="
        font-size: clamp(1rem, 2vw, 1.2rem);
        color: var(--muted);
        line-height: 1.75;
        max-width: 560px;
        margin-bottom: 2.5rem;
      ">
        Negócios locais em qualquer cidade do Brasil perdem clientes todo dia para quem aparece antes deles no Google. A Operaio existe para virar esse jogo.
      </p>

      <!-- CTAs -->
      <div style="display: flex; gap: 1rem; flex-wrap: wrap; align-items: center; margin-bottom: 4rem;">
        <a href="#contato" class="btn-primary" style="font-size: 1rem; padding: 0.875rem 2rem;">
          Diagnóstico gratuito →
        </a>
        <a href="#servicos" class="btn-secondary">
          Ver serviços
        </a>
      </div>

      <!-- Stats strip -->
      <div style="
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0;
        max-width: 640px;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        background: var(--card);
      ">
        {[
          { num: '+40%', label: 'Mais cliques no Google' },
          { num: '3–6×', label: 'Retorno sobre investimento' },
          { num: '100%', label: 'Remoto — qualquer cidade' },
        ].map((s, i) => (
          <div style={`padding: 1.5rem; text-align: center; ${i < 2 ? 'border-right: 1px solid var(--border);' : ''}`}>
            <div style="font-size: 1.75rem; font-weight: 900; color: var(--accent); letter-spacing: -0.03em;">{s.num}</div>
            <div style="font-size: 0.75rem; color: var(--muted); margin-top: 0.25rem;">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       MARQUEE — Cidades atendidas
  ═══════════════════════════════════════════ -->
  <div style="
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 0.875rem 0;
    overflow: hidden;
    background: var(--card);
    position: relative;
  ">
    <!-- fade edges -->
    <div style="position:absolute;left:0;top:0;bottom:0;width:80px;background:linear-gradient(to right,var(--card),transparent);z-index:2;pointer-events:none;"></div>
    <div style="position:absolute;right:0;top:0;bottom:0;width:80px;background:linear-gradient(to left,var(--card),transparent);z-index:2;pointer-events:none;"></div>

    <div class="marquee-track">
      {[
        'São Paulo','Rio de Janeiro','Belo Horizonte','Curitiba','Fortaleza',
        'Recife','Salvador','Manaus','Porto Alegre','Florianópolis',
        'Goiânia','Campinas','Natal','Belém','Brasília','Vitória',
        'Maceió','São Luís','Cuiabá','Anápolis',
        // repeat for seamless loop
        'São Paulo','Rio de Janeiro','Belo Horizonte','Curitiba','Fortaleza',
        'Recife','Salvador','Manaus','Porto Alegre','Florianópolis',
        'Goiânia','Campinas','Natal','Belém','Brasília','Vitória',
        'Maceió','São Luís','Cuiabá','Anápolis',
      ].map((city, i) => (
        <span style="
          display: inline-flex;
          align-items: center;
          gap: 1rem;
          padding: 0 1.5rem;
          font-size: 0.8rem;
          font-weight: 600;
          letter-spacing: 0.06em;
          text-transform: uppercase;
          color: var(--muted);
          white-space: nowrap;
        ">
          <span style="width:4px;height:4px;border-radius:50%;background:var(--accent);flex-shrink:0;"></span>
          {city}
        </span>
      ))}
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       PROBLEMA — Vazamento invisível
  ═══════════════════════════════════════════ -->
  <section style="padding: 5rem 0; background: var(--card); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
    <div class="container" style="text-align: center;">
      <p style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); margin-bottom: 1rem;">O problema</p>
      <h2 style="font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 800; max-width: 700px; margin: 0 auto 1.5rem;">
        Em toda cidade do Brasil,<br/>o mesmo problema.
      </h2>
      <p style="color: var(--muted); font-size: 1.05rem; max-width: 560px; margin: 0 auto 3rem; line-height: 1.75;">
        De Belém a Porto Alegre, negócios locais perdem clientes todo dia para quem aparece antes no Google. O problema não é falta de produto — é invisibilidade digital.
      </p>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1.5rem; max-width: 800px; margin: 0 auto;">
        {[
          { icon: '⚡', texto: 'Site lento ou sem mobile' },
          { icon: '📍', texto: 'Google Meu Negócio desatualizado' },
          { icon: '🔍', texto: 'Não aparece nas buscas locais' },
          { icon: '📉', texto: 'Site que não converte visitantes' },
        ].map(item => (
          <div style="
            padding: 1.25rem 1.5rem;
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: 10px;
            display: flex;
            align-items: center;
            gap: 0.75rem;
          ">
            <span style="font-size: 1.25rem;">{item.icon}</span>
            <span style="font-size: 0.875rem; color: var(--muted); text-align: left;">{item.texto}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       COMO FUNCIONA
  ═══════════════════════════════════════════ -->
  <section id="como-funciona" style="padding: 6rem 0;">
    <div class="container">
      <div style="text-align: center; margin-bottom: 4rem;">
        <p style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); margin-bottom: 1rem;">Processo</p>
        <h2 style="font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 800;">
          Como funciona
        </h2>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 2rem;">
        {etapas.map((e) => (
          <div class="card" style="padding: 2rem; position: relative; overflow: hidden;">
            <div style="
              position: absolute;
              top: 1.5rem;
              right: 1.5rem;
              font-size: 3rem;
              font-weight: 900;
              color: var(--border);
              line-height: 1;
              letter-spacing: -0.05em;
              font-family: 'Inter', monospace;
            ">{e.num}</div>
            <div style="
              width: 3rem;
              height: 3rem;
              background: rgba(16,185,129,0.1);
              border: 1px solid rgba(16,185,129,0.2);
              border-radius: 10px;
              display: flex;
              align-items: center;
              justify-content: center;
              margin-bottom: 1.25rem;
              font-size: 1.25rem;
              font-weight: 900;
              color: var(--accent);
            ">{e.num.replace('0','')}</div>
            <h3 style="font-size: 1.25rem; font-weight: 700; margin-bottom: 0.75rem;">{e.titulo}</h3>
            <p style="color: var(--muted); font-size: 0.9rem; line-height: 1.7;">{e.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CASO REAL
  ═══════════════════════════════════════════ -->
  <section style="padding: 6rem 0; border-top: 1px solid var(--border);">
    <div class="container">

      <!-- Label -->
      <div style="display:flex;align-items:center;gap:1rem;margin-bottom:3.5rem;">
        <div style="height:1px;width:3rem;background:var(--accent);"></div>
        <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--accent);">Caso real</p>
      </div>

      <!-- Editorial grid: large left + right stack -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start;">

        <!-- Left — the story -->
        <div>
          <p style="font-size:0.85rem;color:var(--muted);margin-bottom:1rem;">Clínica odontológica · Goiânia, GO</p>
          <h2 style="font-size:clamp(1.75rem,3.5vw,2.5rem);font-weight:900;line-height:1.1;margin-bottom:1.5rem;">
            De 12 para 89<br/>
            <span style="color:var(--accent);">novos pacientes/mês.</span>
          </h2>
          <p style="color:var(--muted);line-height:1.8;margin-bottom:1.5rem;font-size:0.95rem;">
            A clínica tinha site, tinha Instagram, tinha Google Meu Negócio — mas não aparecia nas buscas "dentista Goiânia". O concorrente a 200m ocupava as 3 primeiras posições.
          </p>
          <p style="color:var(--muted);line-height:1.8;font-size:0.95rem;">
            Em 90 dias: site otimizado, GMN completo com 47 novas avaliações, e posição #2 para "dentista Goiânia". Agenda lotada pela primeira vez em 4 anos.
          </p>
          <div style="margin-top:2rem;padding-top:2rem;border-top:1px solid var(--border);">
            <p style="font-size:0.8rem;color:var(--muted);font-style:italic;">"Nunca pensei que SEO seria o maior investimento que fiz na clínica."</p>
            <p style="font-size:0.8rem;color:var(--muted);margin-top:0.5rem;font-weight:600;">— Dr. R. Albuquerque, clínica parceira</p>
          </div>
        </div>

        <!-- Right — metrics stack (asymmetric) -->
        <div style="display:flex;flex-direction:column;gap:1.25rem;padding-top:0.5rem;">

          <!-- Big metric -->
          <div style="
            background:linear-gradient(135deg,rgba(16,185,129,0.1),rgba(16,185,129,0.04));
            border:1px solid rgba(16,185,129,0.25);
            border-radius:16px;
            padding:2rem;
          ">
            <div style="font-size:0.7rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--accent);margin-bottom:0.75rem;">Posicionamento Google</div>
            <div style="display:flex;align-items:flex-end;gap:1.5rem;">
              <div>
                <div style="font-size:0.7rem;color:var(--muted);margin-bottom:0.25rem;">ANTES</div>
                <div style="font-size:3rem;font-weight:900;color:var(--muted);letter-spacing:-0.04em;line-height:1;">#47</div>
              </div>
              <div style="font-size:1.5rem;color:var(--border);margin-bottom:0.75rem;">→</div>
              <div>
                <div style="font-size:0.7rem;color:var(--accent);margin-bottom:0.25rem;">DEPOIS</div>
                <div style="font-size:3rem;font-weight:900;color:var(--accent);letter-spacing:-0.04em;line-height:1;">#2</div>
              </div>
            </div>
            <div style="font-size:0.75rem;color:var(--muted);margin-top:0.75rem;">para "dentista Goiânia" · 90 dias</div>
          </div>

          <!-- Two smaller metrics side by side -->
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;">
            <div style="background:var(--card);border:1px solid var(--border);border-radius:12px;padding:1.5rem;">
              <div style="font-size:0.7rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted);margin-bottom:0.5rem;">Novos pacientes</div>
              <div style="font-size:2rem;font-weight:900;letter-spacing:-0.03em;">+643<span style="font-size:1rem;color:var(--accent);">%</span></div>
              <div style="font-size:0.72rem;color:var(--muted);margin-top:0.25rem;">12 → 89/mês</div>
            </div>
            <div style="background:var(--card);border:1px solid var(--border);border-radius:12px;padding:1.5rem;">
              <div style="font-size:0.7rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted);margin-bottom:0.5rem;">Avaliações Google</div>
              <div style="font-size:2rem;font-weight:900;letter-spacing:-0.03em;">47<span style="font-size:1rem;color:var(--accent);"> novas</span></div>
              <div style="font-size:0.72rem;color:var(--muted);margin-top:0.25rem;">nota 4.9 ★</div>
            </div>
          </div>

          <!-- Timeline bar -->
          <div style="background:var(--card);border:1px solid var(--border);border-radius:12px;padding:1.5rem;">
            <div style="font-size:0.7rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted);margin-bottom:1rem;">Linha do tempo</div>
            <div style="display:flex;gap:0;position:relative;">
              {[
                {label:'Diagnóstico',day:'Dia 1'},
                {label:'Site live',day:'Dia 18'},
                {label:'GMN ok',day:'Dia 30'},
                {label:'Top 3',day:'Dia 90'},
              ].map((item, i, arr) => (
                <div style={`flex:1;position:relative;${i < arr.length-1 ? '' : ''}`}>
                  <div style={`
                    width:8px;height:8px;border-radius:50%;margin-bottom:0.5rem;
                    background:${i === arr.length-1 ? 'var(--accent)' : 'var(--border)'};
                    border:2px solid ${i === arr.length-1 ? 'var(--accent)' : 'var(--border)'};
                    position:relative;z-index:1;
                  `}></div>
                  ${i < arr.length-1 ? `<div style="position:absolute;top:3px;left:8px;right:0;height:2px;background:var(--border);"></div>` : ''}
                  <div style="font-size:0.65rem;font-weight:700;color:var(--accent);">{item.day}</div>
                  <div style="font-size:0.65rem;color:var(--muted);margin-top:0.1rem;">{item.label}</div>
                </div>
              ))}
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       SERVIÇOS / PACOTES
  ═══════════════════════════════════════════ -->
  <section id="servicos" style="padding: 6rem 0; background: var(--card); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
    <div class="container">
      <div style="text-align: center; margin-bottom: 4rem;">
        <p style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); margin-bottom: 1rem;">Pacotes</p>
        <h2 style="font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 800; margin-bottom: 1rem;">
          Escolha seu ponto de entrada
        </h2>
        <p style="color: var(--muted); font-size: 1rem; max-width: 480px; margin: 0 auto;">
          100% remoto. Atendemos negócios em qualquer cidade do Brasil. Começamos com diagnóstico e escalamos conforme o resultado aparece.
        </p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.5rem;">
        {pacotes.map((p) => (
          <div style={`
            background: ${p.destaque ? 'linear-gradient(135deg, rgba(16,185,129,0.12), rgba(16,185,129,0.05))' : 'var(--bg)'};
            border: 1px solid ${p.destaque ? 'var(--accent)' : 'var(--border)'};
            border-radius: 16px;
            padding: 2rem;
            position: relative;
            transition: all 0.2s;
            ${p.destaque ? 'box-shadow: 0 0 40px rgba(16,185,129,0.12);' : ''}
          `}>
            {p.destaque && (
              <div style="
                position: absolute;
                top: -12px;
                left: 50%;
                transform: translateX(-50%);
                background: var(--accent);
                color: var(--bg);
                font-size: 0.7rem;
                font-weight: 700;
                letter-spacing: 0.08em;
                padding: 0.3rem 1rem;
                border-radius: 100px;
                white-space: nowrap;
              ">MAIS ESCOLHIDO</div>
            )}

            <p style="font-size: 0.75rem; color: var(--muted); font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 0.5rem;">{p.subtitulo}</p>
            <h3 style="font-size: 1.25rem; font-weight: 800; margin-bottom: 1.5rem;">{p.nome}</h3>

            <div style="margin-bottom: 1.5rem;">
              <span style="font-size: 2rem; font-weight: 900; letter-spacing: -0.03em;">{p.preco}</span>
              <span style="color: var(--muted); font-size: 0.8rem; margin-left: 0.25rem;">{p.recorrencia}</span>
            </div>

            <ul style="list-style: none; margin-bottom: 2rem; display: flex; flex-direction: column; gap: 0.6rem;">
              {p.itens.map(item => (
                <li style="display: flex; gap: 0.6rem; align-items: flex-start; font-size: 0.875rem; color: var(--muted);">
                  <span style="color: var(--accent); flex-shrink: 0; margin-top: 0.05rem;">✓</span>
                  {item}
                </li>
              ))}
            </ul>

            <a href="#contato" style={`
              display: block;
              text-align: center;
              padding: 0.75rem;
              border-radius: 8px;
              font-weight: 700;
              font-size: 0.875rem;
              text-decoration: none;
              transition: all 0.2s;
              ${p.destaque
                ? 'background: var(--accent); color: var(--bg);'
                : 'background: transparent; border: 1px solid var(--border); color: var(--text);'}
            `}
            onmouseover={p.destaque
              ? "this.style.background='var(--accent-hover)'"
              : "this.style.borderColor='var(--accent)'; this.style.color='var(--accent)'"}
            onmouseout={p.destaque
              ? "this.style.background='var(--accent)'"
              : "this.style.borderColor='var(--border)'; this.style.color='var(--text)'"}
            >
              {p.cta}
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       VALORES
  ═══════════════════════════════════════════ -->
  <section id="sobre" style="padding: 6rem 0;">
    <div class="container">
      <div style="
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 5rem;
