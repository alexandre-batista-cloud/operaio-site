---
import Layout from '../layouts/Layout.astro';

const pacotes = [
  {
    nome: 'Diagnóstico Raio-X',
    subtitulo: 'Onde você está perdendo vendas',
    preco: 'R$497',
    recorrencia: 'único',
    destaque: false,
    itens: [
      'Auditoria completa do site',
      'Análise de posicionamento Google',
      'Relatório de oportunidades locais',
      'Mapa de atrito digital',
      'Plano de ação em 30 dias',
    ],
    cta: 'Quero meu diagnóstico',
  },
  {
    nome: 'Vitrine Inteligente',
    subtitulo: 'Presença local que converte',
    preco: 'R$2.800',
    recorrencia: '+ R$1.200/mês',
    destaque: false,
    itens: [
      'Site otimizado para SEO local',
      'Google Meu Negócio configurado',
      'Schema markup completo',
      'Relatório mensal de posições',
      'Suporte e ajustes contínuos',
    ],
    cta: 'Começar agora',
  },
  {
    nome: 'Landing de Conversão',
    subtitulo: 'Página que fecha clientes',
    preco: 'R$2.500',
    recorrencia: '+ R$900/mês',
    destaque: true,
    itens: [
      'Landing page de alta conversão',
      'Copywriting estratégico',
      'Integração com WhatsApp/e-mail',
      'Testes A/B contínuos',
      'Analytics e relatório semanal',
    ],
    cta: 'Quero converter mais',
  },
  {
    nome: 'Tráfego Pago',
    subtitulo: 'Visibilidade que gera venda',
    preco: 'R$1.500',
    recorrencia: '/mês + verba',
    destaque: false,
    itens: [
      'Google Ads e Meta Ads',
      'Segmentação local e por intenção',
      'Remarketing e captação de leads',
      'Relatório semanal de performance',
      'Otimização contínua de campanhas',
    ],
    cta: 'Quero mais tráfego',
  },
  {
    nome: 'Site Authority',
    subtitulo: 'Autoridade total no digital',
    preco: 'R$7.000',
    recorrencia: '+ R$2.500/mês',
    destaque: false,
    itens: [
      'Site completo multi-página',
      'Blog com estratégia de conteúdo',
      'SEO técnico avançado',
      'GEO — citações em IA',
      'Gestão digital full service',
    ],
    cta: 'Quero ser autoridade',
  },
];

const etapas = [
  {
    num: '01',
    titulo: 'Diagnóstico',
    desc: 'Mapeamos onde seu negócio está perdendo vendas no digital: posicionamento Google, site, operação. 30 minutos, resultado concreto.',
  },
  {
    num: '02',
    titulo: 'Sistema',
    desc: 'Montamos o sistema digital certo para o seu negócio. Site, SEO local, Google Meu Negócio — tudo integrado e funcionando junto.',
  },
  {
    num: '03',
    titulo: 'Resultado',
    desc: 'Mais cliques no Google, mais visitas, mais conversões. Acompanhamos os números e ajustamos continuamente para crescer.',
  },
];

const valores = [
  {
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`,
    titulo: 'Integridade',
    desc: 'Dizemos o que é possível, entregamos o que prometemos. Sem métricas de vaidade, sem relatórios vazios.',
  },
  {
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
    titulo: 'Responsabilidade',
    desc: 'Seu resultado é nossa responsabilidade. Não desaparecemos após o setup — acompanhamos cada etapa.',
  },
  {
    svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`,
    titulo: 'Visão de resultado',
    desc: 'Cada decisão técnica existe para gerar negócio. SEO, site e conteúdo como sistema de vendas, não como custo.',
  },
];
---

<Layout>

  <!-- ═══════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════ -->
  <section class="dobra-hero" style="
    padding: 7rem 0 5rem;
    position: relative;
    overflow: hidden;
  ">
    <!-- Dot grid texture -->
    <div class="hero-texture"></div>

    <!-- Background glow -->
    <div style="
      position: absolute;
      top: -200px;
      right: -200px;
      width: 600px;
      height: 600px;
      background: radial-gradient(circle, rgba(16,185,129,0.08) 0%, transparent 70%);
      pointer-events: none;
    "></div>
    <div style="
      position: absolute;
      bottom: -100px;
      left: -100px;
      width: 400px;
      height: 400px;
      background: radial-gradient(circle, rgba(240,90,40,0.05) 0%, transparent 70%);
      pointer-events: none;
    "></div>

    <div class="container" style="position: relative; z-index: 1;">
      <!-- Badge -->
      <div style="
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(16,185,129,0.1);
        border: 1px solid rgba(16,185,129,0.2);
        padding: 0.375rem 1rem;
        border-radius: 100px;
        margin-bottom: 2rem;
      ">
        <span style="width: 6px; height: 6px; background: var(--accent); border-radius: 50%; display: inline-block; animation: pulse 2s infinite;"></span>
        <span style="color: var(--accent); font-size: 0.8rem; font-weight: 600; letter-spacing: 0.05em;">GOIÂNIA · ANÁPOLIS · REGIÃO — SEO LOCAL E CONVERSÃO</span>
      </div>

      <!-- Headline -->
      <h1 style="
        font-size: clamp(2.75rem, 6vw, 5rem);
        font-weight: 900;
        line-height: 1.05;
        letter-spacing: -0.03em;
        max-width: 800px;
        margin-bottom: 1.75rem;
      ">
        Seu negócio <span style="color: var(--accent);">aparece no Google</span><br/>
        e fecha mais clientes.
      </h1>

      <p style="
        font-size: clamp(1rem, 2vw, 1.2rem);
        color: var(--muted);
        line-height: 1.75;
        max-width: 560px;
        margin-bottom: 2.5rem;
      ">
        Negócios locais em qualquer cidade do Brasil perdem clientes todo dia para quem aparece antes deles no Google. A Operaio existe para virar esse jogo.
      </p>

      <!-- CTAs -->
      <div style="display: flex; gap: 1rem; flex-wrap: wrap; align-items: center; margin-bottom: 4rem;">
        <a href="#contato" class="btn-primary" style="font-size: 1rem; padding: 0.875rem 2rem;">
          Diagnóstico gratuito →
        </a>
        <a href="#servicos" class="btn-secondary">
          Ver serviços
        </a>
      </div>

      <!-- Stats strip -->
      <div class="hero-stats" style="
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 0;
        max-width: 640px;
        border: 1px solid var(--border);
        border-radius: 12px;
        overflow: hidden;
        background: var(--card);
        margin-bottom: 3rem;
      ">
        {[
          { num: '+40%', label: 'Mais cliques no Google' },
          { num: '3–6×', label: 'Retorno sobre investimento' },
          { num: '100%', label: 'Remoto — qualquer cidade' },
        ].map((s, i) => (
          <div style={`padding: 1.5rem; text-align: center; ${i < 2 ? 'border-right: 1px solid var(--border);' : ''}`}>
            <div style="font-size: 1.75rem; font-weight: 900; color: var(--accent); letter-spacing: -0.03em;">{s.num}</div>
            <div style="font-size: 0.75rem; color: var(--muted); margin-top: 0.25rem;">{s.label}</div>
          </div>
        ))}
      </div>

      <!-- Step strip — padrão HMetrix -->
      <div class="hero-steps-strip" style="max-width: 640px; position: relative;">
        <!-- connecting line -->
        <div style="
          position: absolute;
          top: 14px;
          left: calc(14px + 33.333% / 2);
          right: calc(14px + 33.333% / 2);
          height: 2px;
          background: var(--border);
          z-index: 0;
        "></div>
        <div style="display: flex; align-items: flex-start; gap: 0;">
          {[
            { num: '1', titulo: 'Diagnóstico', desc: '30 min · resultado concreto' },
            { num: '2', titulo: 'Sistema montado', desc: 'SEO, site e GMN integrados' },
            { num: '3', titulo: 'Resultado real', desc: 'Mais cliques, mais vendas' },
          ].map((step) => (
            <div style="flex: 1; display: flex; flex-direction: column; align-items: center; text-align: center; position: relative; z-index: 1;">
              <div style="
                width: 28px;
                height: 28px;
                border-radius: 50%;
                background: var(--accent);
                color: var(--bg);
                font-size: 0.72rem;
                font-weight: 800;
                display: flex;
                align-items: center;
                justify-content: center;
                margin-bottom: 0.65rem;
                flex-shrink: 0;
              ">{step.num}</div>
              <div style="font-size: 0.8rem; font-weight: 700; color: var(--text); margin-bottom: 0.2rem;">{step.titulo}</div>
              <div style="font-size: 0.7rem; color: var(--muted); line-height: 1.4;">{step.desc}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       MARQUEE — Cidades atendidas
  ═══════════════════════════════════════════ -->
  <div style="
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 0.875rem 0;
    overflow: hidden;
    background: var(--card);
    position: relative;
  ">
    <!-- fade edges -->
    <div style="position:absolute;left:0;top:0;bottom:0;width:80px;background:linear-gradient(to right,var(--card),transparent);z-index:2;pointer-events:none;"></div>
    <div style="position:absolute;right:0;top:0;bottom:0;width:80px;background:linear-gradient(to left,var(--card),transparent);z-index:2;pointer-events:none;"></div>

    <div class="marquee-track">
      {[
        'Goiânia','Anápolis','Aparecida de Goiânia','Senador Canedo','Trindade',
        'Goianira','Nerópolis','Inhumas','Jaraguá','Pirenópolis',
        'Hidrolândia','Goianápolis','Leopoldo de Bulhões','Alexânia','Silvânia',
        'Campo Limpo de Goiás','Itaberaí','Ceres','Ouro Verde de Goiás','Uruana',
        // repeat for seamless loop
        'Goiânia','Anápolis','Aparecida de Goiânia','Senador Canedo','Trindade',
        'Goianira','Nerópolis','Inhumas','Jaraguá','Pirenópolis',
        'Hidrolândia','Goianápolis','Leopoldo de Bulhões','Alexânia','Silvânia',
        'Campo Limpo de Goiás','Itaberaí','Ceres','Ouro Verde de Goiás','Uruana',
      ].map((city, i) => (
        <span style="
          display: inline-flex;
          align-items: center;
          gap: 1rem;
          padding: 0 1.5rem;
          font-size: 0.8rem;
          font-weight: 600;
          letter-spacing: 0.06em;
          text-transform: uppercase;
          color: var(--muted);
          white-space: nowrap;
        ">
          <span style="width:4px;height:4px;border-radius:50%;background:var(--accent);flex-shrink:0;"></span>
          {city}
        </span>
      ))}
    </div>
  </div>

  <!-- ═══════════════════════════════════════════
       PROBLEMA — Vazamento invisível
  ═══════════════════════════════════════════ -->
  <section class="dobra-problema" style="padding: 5rem 0; background: var(--card); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
    <div class="container" style="text-align: center;">
      <p style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); margin-bottom: 1rem;">O problema</p>
      <h2 style="font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 800; max-width: 700px; margin: 0 auto 1.5rem;">
        Em toda cidade do Brasil,<br/>o mesmo problema.
      </h2>
      <p style="color: var(--muted); font-size: 1.05rem; max-width: 560px; margin: 0 auto 3rem; line-height: 1.75;">
        De Belém a Porto Alegre, negócios locais perdem clientes todo dia para quem aparece antes no Google. O problema não é falta de produto — é invisibilidade digital.
      </p>

      <div class="problema-grid" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem; margin: 0 auto;">
        {[
          {
            svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
            texto: 'Site lento ou sem mobile',
          },
          {
            svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>`,
            texto: 'Google Meu Negócio desatualizado',
          },
          {
            svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
            texto: 'Não aparece nas buscas locais',
          },
          {
            svg: `<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 18 13.5 8.5 8.5 13.5 1 6"/><polyline points="17 18 23 18 23 12"/></svg>`,
            texto: 'Site que não converte visitantes',
          },
        ].map(item => (
          <div style="
            padding: 1.25rem 1.5rem;
            background: var(--bg);
            border: 1px solid var(--border);
            border-radius: 10px;
            display: flex;
            align-items: center;
            gap: 0.75rem;
          ">
            <span style="color: var(--accent); flex-shrink: 0; display: flex;" set:html={item.svg} />
            <span style="font-size: 0.875rem; color: var(--muted); text-align: left;">{item.texto}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       COMO FUNCIONA — padrão HMetrix horizontal
  ═══════════════════════════════════════════ -->
  <section id="como-funciona" style="padding: 6rem 0; background: var(--card); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
    <div class="container">
      <div style="text-align: center; margin-bottom: 4rem;">
        <p style="font-size: 0.75rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: var(--accent); margin-bottom: 1rem;">Processo</p>
        <h2 style="font-size: clamp(1.75rem, 4vw, 2.75rem); font-weight: 800;">
          Você no controle do seu <span style="color: var(--accent);">crescimento digital</span>
        </h2>
      </div>

      <!-- Horizontal connected steps — HMetrix pattern -->
      <div style="position: relative; max-width: 860px; margin: 0 auto;">
        <!-- connecting line desktop -->
        <div class="steps-line"></div>

        <div class="steps-h-grid" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem;">
          {etapas.map((e, i) => (
            <div style="display: flex; flex-direction: column; align-items: center; text-align: center; position: relative; z-index: 1;">
              <!-- Circle -->
              <div style={`
                width: 52px;
                height: 52px;
                border-radius: 50%;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 1.1rem;
                font-weight: 900;
                margin-bottom: 1.25rem;
                flex-shrink: 0;
                ${i === 2
                  ? 'background: var(--accent); color: var(--bg); box-shadow: 0 0 24px rgba(16,185,129,0.35);'
                  : 'background: var(--bg); color: var(--accent); border: 2px solid rgba(16,185,129,0.4);'}
              `}>{e.num.replace('0','')}</div>
              <h3 style="font-size: 1.1rem; font-weight: 700; margin-bottom: 0.65rem;">{e.titulo}</h3>
              <p style="color: var(--muted); font-size: 0.875rem; line-height: 1.7;">{e.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════
       CASO REAL
  ═══════════════════════════════════════════ -->
  <section class="dobra-caso-real" style="padding: 6rem 0; border-top: 1px solid var(--border);">
    <div class="container">

      <!-- Label -->
      <div style="display:flex;align-items:center;gap:1rem;margin-bottom:3.5rem;">
        <div style="height:1px;width:3rem;background:var(--accent);"></div>
        <p style="font-size:0.75rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--accent);">Caso real</p>
      </div>

      <!-- Editorial grid: large left + right stack -->
      <div class="grid-2col" style="display:grid;grid-template-columns:1fr 1fr;gap:4rem;align-items:start;">

        <!-- Left — the story -->
        <div>
          <p style="font-size:0.85rem;color:var(--muted);margin-bottom:1rem;">Franquia de colchões · Anápolis, GO</p>
          <h2 style="font-size:clamp(1.75rem,3.5vw,2.5rem);font-weight:900;line-height:1.1;margin-bottom:1.5rem;">
            De R$60k/mês para<br/>
            <span style="color:var(--accent);">R$600k em uma Black Friday.</span>
          </h2>
          <p style="color:var(--muted);line-height:1.8;margin-bottom:1.5rem;font-size:0.95rem;">
            A franquia vendia bem — mas dependia do fluxo da loja física. Presença digital quase zero, sem tráfego orgânico, sem estratégia de data comemorativa. O concorrente online crescia enquanto a loja esperava o cliente entrar.
          </p>
          <p style="color:var(--muted);line-height:1.8;font-size:0.95rem;">
            Implementamos SEO local, reestruturamos o Google Meu Negócio e montamos uma estratégia de conteúdo e tráfego focada em datas-chave. Na primeira Black Friday com o sistema rodando: R$600k — dez vezes o faturamento mensal anterior. Em 3 anos: R$5 milhões acumulados.
          </p>
          <div style="margin-top:2rem;padding-top:2rem;border-top:1px solid var(--border);">
            <p style="font-size:1rem;color:var(--text);font-style:italic;line-height:1.7;">"Eu tratava marketing como custo. Depois desse resultado, passei a tratar como o único investimento que realmente escala o negócio."</p>
            <p style="font-size:0.8rem;color:var(--muted);margin-top:0.75rem;font-weight:600;">— Valkiria, franqueada · Anápolis, GO</p>
          </div>
        </div>

        <!-- Right — metrics stack (asymmetric) -->
        <div style="display:flex;flex-direction:column;gap:1.25rem;padding-top:0.5rem;">

          <!-- Big metric -->
          <div style="
            background:linear-gradient(135deg,rgba(16,185,129,0.1),rgba(16,185,129,0.04));
            border:1px solid rgba(16,185,129,0.25);
            border-radius:16px;
            padding:2rem;
          ">
            <div style="font-size:0.7rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:var(--accent);margin-bottom:0.75rem;">Faturamento — Black Friday</div>
            <div style="display:flex;align-items:flex-end;gap:1.5rem;">
              <div>
                <div style="font-size:0.7rem;color:var(--muted);margin-bottom:0.25rem;">ANTES (mês)</div>
                <div class="metric-number" style="font-size:2.25rem;font-weight:900;color:var(--muted);letter-spacing:-0.04em;line-height:1;">R$60k</div>
              </div>
              <div style="font-size:1.5rem;color:var(--border);margin-bottom:0.75rem;">→</div>
              <div>
                <div style="font-size:0.7rem;color:var(--accent);margin-bottom:0.25rem;">1ª BLACK FRIDAY</div>
                <div class="metric-glow" style="font-size:2.25rem;font-weight:900;color:var(--accent);letter-spacing:-0.04em;line-height:1;">R$600k</div>
              </div>
            </div>
            <div style="font-size:0.75rem;color:var(--muted);margin-top:0.75rem;">10× o faturamento mensal · em uma campanha bem estruturada</div>
          </div>

          <!-- Two smaller metrics side by side -->
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;">
            <div style="background:var(--card);border:1px solid var(--border);border-radius:12px;padding:1.5rem;">
              <div style="font-size:0.7rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted);margin-bottom:0.5rem;">Acumulado 3 anos</div>
              <div class="metric-number" style="font-size:2rem;font-weight:900;letter-spacing:-0.03em;animation-delay:0.15s;">R$5<span style="font-size:1rem;color:var(--accent);">M</span></div>
              <div style="font-size:0.72rem;color:var(--muted);margin-top:0.25rem;">vs R$600k no período anterior</div>
            </div>
            <div style="background:var(--card);border:1px solid var(--border);border-radius:12px;padding:1.5rem;">
              <div style="font-size:0.7rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted);margin-bottom:0.5rem;">Crescimento total</div>
              <div class="metric-number" style="font-size:2rem;font-weight:900;letter-spacing:-0.03em;animation-delay:0.3s;">+733<span style="font-size:1rem;color:var(--accent);">%</span></div>
              <div style="font-size:0.72rem;color:var(--muted);margin-top:0.25rem;">em receita nos 3 anos</div>
            </div>
          </div>

          <!-- Timeline bar -->
          <div style="background:var(--card);border:1px solid var(--border);border-radius:12px;padding:1.5rem;">
            <div style="font-size:0.7rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:var(--muted);margin-bottom:1rem;">Linha do tempo</div>
            <div style="display:flex;gap:0;position:relative;">
              {[
                {label:'Diagnóstico',day:'Mês 1'},
                {label:'SEO + GMN',day:'Mês 2'},
